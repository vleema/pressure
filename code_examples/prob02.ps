main :: fn() {
    count25 := 0;
    count50 := 0;
    count75 := 0;
    count100 := 0;
    while true {
        x :: @as(int, @read());
        if x == -1 { break; };
        if x <= 25 {
            count25 += 1;
        } else if x <= 50 {
            count50 += 1;
        } else if x <= 75 {
            count75 += 1;
        } else if x <= 100 {
            count100 += 1;
        };
    };
    @printf("[0,25]={}\n[26,50]={}\n[51,75]={}\n[76,100]={}\n", count25, count50, count75, count100);
};

