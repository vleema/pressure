main :: fn(){
    x := @as(int, @read());
    
    r25count := 0;
    r50count := 0;
    r75count := 0;
    r100count := 0;

    while x >= 0{
        if x <= 25{
            r25count +=1;
        }
        else{
            if x <= 50{
                r50count +=1;
            }
            else{
                if x <= 75{
                    r75count +=1;
                }
                else{
                    if x <= 100{
                        r100count +=1;
                    }
                }
            }
        };
        x = @as(int, @read());
    };
    @printf("(r25, r50, r75, r100) = ({}, {}, {}, {})", r25count, r50count, r75count, r100count);
};


main();